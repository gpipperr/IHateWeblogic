# IHateWeblogic – Git Ignore
# Generated and sensitive files – DO NOT COMMIT

# Session/prompt documents (local only)
oracle_forms_reports_prompt_v2.md

# Generated environment configuration (symlink target)
environment.conf
environment.conf.bak*

# Per-environment conf files (server-specific paths, never commit)
# Templates (*.template) and README.md are committed
00-Setup/environments/*.conf

# DB-specific generated configuration (machine-specific paths + credentials)
60-RCU-DB-19c/environment_db.conf

# Setup interview output (contains local paths, generated by setup interview)
setup.conf

# Encrypted password files (machine-specific) and their backups
*.des3
*.des3.bak*

# Plaintext config files (exist only briefly at runtime)
weblogic_sec.conf

# Debug helper – displays plaintext passwords (local only, never commit)
00-Setup/getPWDs.sh

# SSL certificate configuration (server-specific; template is committed)
08-SSL/ssl.conf
# Generated certificates and keys (never commit private keys)
08-SSL/certs/

# Log output directories
log/

# Backup directories (contain local config)
07-Maintenance/ConfigBackup/*/

# Font cache
*.cache

# Claude Code session data (local only)
.claude/
CLAUDE.md

# Editor artifacts
*.swp
*.swo
*~
.DS_Store

# RAG source data – not committed (binary files / Oracle license terms)
# Place documents here locally for use as RAG knowledge base
90-Source-MetaData/


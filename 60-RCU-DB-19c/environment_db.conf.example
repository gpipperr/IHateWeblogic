# =============================================================================
# environment_db.conf  –  Oracle 19c RCU Database configuration
# =============================================================================
# Copy to environment_db.conf and edit before running any 60-RCU-DB-19c script.
# chmod 600 environment_db.conf
#
# This file is SEPARATE from environment.conf (FMW/WLS).
# The two files share ROOT_DIR and the lib, but no variables overlap.
#
# Bridge to FMW: after the PDB is running, set in environment.conf:
#   DB_HOST=...  DB_PORT=1521  DB_SERVICE=FMWPDB
# =============================================================================

# --- Oracle Base and Homes ---------------------------------------------------
DB_BASE="/u01/app/oracle"
DB_ORACLE_HOME="${DB_BASE}/product/19c/dbhome_1"    # patched target home
DB_ORACLE_HOME_BASE="${DB_BASE}/product/19c/19base"  # unpatched 19.3 base home

# --- Database Identity -------------------------------------------------------
DB_SID="FMWCDB"
DB_CDB_NAME="FMWCDB"
DB_PDB_NAME="FMWPDB"

# --- Memory (Automatic Memory Management) ------------------------------------
# MEMORY_TARGET controls total SGA + PGA.
# Minimum: 1536  (1.5 GB)  – tight, for dev only
# Recommended: 2048  (2 GB)  – comfortable for FMW domain startup
# Note: with HugePages, use SGA_TARGET + PGA_AGGREGATE_TARGET instead of MEMORY_TARGET
DB_MEMORY_MB=2048

# --- Storage -----------------------------------------------------------------
DB_DATA_DIR="${DB_BASE}/oradata"         # datafile location
DB_FAST_RECOVERY_AREA=""                 # leave empty – archivelog OFF for dev

# --- Listener ----------------------------------------------------------------
DB_LISTENER_PORT=1521

# --- Character Set -----------------------------------------------------------
# AL32UTF8 is required by FMW – do not change
DB_CHAR_SET="AL32UTF8"
DB_NCHAR_SET="AL16UTF16"

# --- Processes / Cursors -----------------------------------------------------
DB_PROCESSES=300
DB_OPEN_CURSORS=300

# --- Archivelog --------------------------------------------------------------
# false for dev/test (saves disk, not needed for metadata-only DB)
# true  for production (set DB_FAST_RECOVERY_AREA as well)
DB_ARCHIVELOG=false

# --- Audit Tablespace (04-db_audit_setup.sh) ---------------------------------
DB_AUDIT_TS_SIZE_MB=100            # initial size; purge job keeps it bounded
DB_AUDIT_TS_MAX_MB=4000            # max 4 GB
DB_AUDIT_RETAIN_DAYS=180           # purge records older than N days

# --- Optional: FMW_DATA Tablespace (05-db_fmw_tablespace.sh) -----------------
# Leave empty to let RCU create its own tablespaces (recommended for dev).
# Set to enable pre-created tablespace (enterprise/production).
# Must match RCU_TABLESPACE in environment.conf.
DB_FMW_TABLESPACE=""               # e.g. FMW_DATA
DB_FMW_TABLESPACE_SIZE_MB=500      # initial size

# --- AutoUpgrade / Patching (02-db_patch_autoupgrade.sh) ---------------------
DB_AUTOUPGRADE_HOME="${DB_BASE}/autoupgrade"
DB_TARGET_RU="19.CURRENT"          # or fixed: 19.24
MOS_SEC_FILE="${ROOT_DIR}/mos_sec.conf.des3"   # shared with 09-Install

# --- Install Archive (01-db_install_software.sh) -----------------------------
DB_INSTALL_ARCHIVE=""              # path to LINUX.X64_193000_db_home.zip
